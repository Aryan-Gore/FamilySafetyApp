<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="14dp">

        <!-- Top Row: Icon + Name + Edit/Delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Icon Box -->
            <TextView
                android:id="@+id/tvLocationIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="H"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#43A047"
                android:gravity="center"
                android:background="@drawable/badge_green"
                android:layout_marginEnd="12dp"/>

            <!-- Name + Address -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLocationName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:id="@+id/tvLocationAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to set location"
                    android:textSize="12sp"
                    android:textColor="#757575"/>

            </LinearLayout>

            <!-- Edit Button -->
            <Button
                android:id="@+id/btnEditLocation"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Set"
                android:textSize="11sp"
                android:textColor="#43A047"
                android:backgroundTint="#E8F5E9"
                android:layout_marginStart="6dp"/>

            <!-- Delete Button -->
            <Button
                android:id="@+id/btnDeleteLocation"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Del"
                android:textSize="11sp"
                android:textColor="#C62828"
                android:backgroundTint="#FCE4EC"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="10dp"/>

        <!-- Radius Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zone radius:"
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginEnd="8dp"/>

            <SeekBar
                android:id="@+id/seekBarRadius"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="950"
                android:progress="150"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvRadius"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="200m"
                android:textSize="12sp"
                android:textColor="#212121"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Alerts Toggle Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Get alerts when someone enters or leaves"
                android:textSize="12sp"
                android:textColor="#757575"/>

            <Switch
                android:id="@+id/switchAlerts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:thumbTint="#43A047"
                android:trackTint="#C8E6C9"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
