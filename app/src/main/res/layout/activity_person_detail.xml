<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Back"
            android:textSize="13sp"
            android:textColor="#43A047"
            android:backgroundTint="#E8F5E9"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvTopName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dad"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#212121"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp"
                    android:background="#FFFFFF">

                    <!-- Avatar -->
                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_marginBottom="12dp">

                        <View
                            android:id="@+id/viewAvatar"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="@drawable/circle_green"/>

                        <TextView
                            android:id="@+id/tvInitial"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="D"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>

                    </FrameLayout>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tvNickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dad"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginBottom="4dp"/>

                    <!-- Last Seen -->
                    <TextView
                        android:id="@+id/tvLastSeen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last seen: 2 mins ago"
                        android:textSize="13sp"
                        android:textColor="#757575"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFFFFF">

                    <!-- Address Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Address"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:layout_weight="0"
                            android:minWidth="110dp"/>

                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loading..."
                            android:textSize="13sp"
                            android:textColor="#212121"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#F5F5F5"/>

                    <!-- Distance Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distance from Home"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:minWidth="110dp"/>

                        <TextView
                            android:id="@+id/tvDistance"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Calculating..."
                            android:textSize="13sp"
                            android:textColor="#212121"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#F5F5F5"/>

                    <!-- Battery Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Battery"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:minWidth="110dp"/>

                        <TextView
                            android:id="@+id/tvBattery"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="85%"
                            android:textSize="13sp"
                            android:textColor="#212121"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#F5F5F5"/>

                    <!-- Speed Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:minWidth="110dp"/>

                        <TextView
                            android:id="@+id/tvSpeed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Stationary"
                            android:textSize="13sp"
                            android:textColor="#212121"
                            android:textStyle="bold"
                            android:gravity="end"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnViewOnMap"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="View on Map"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#43A047"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnViewHistory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="View Location History"
                android:textSize="15sp"
                android:textColor="#43A047"
                android:backgroundTint="#E8F5E9"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
